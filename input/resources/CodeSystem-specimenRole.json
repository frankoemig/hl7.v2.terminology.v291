    "id": "3714",
    "code": "B",
    "display": "Blind Sample",
    "definition": "Used to test the validity of the measurement process, where the composition of the sample is unknown except to the person submitting it.",
    "property": [ {
      "code": "modified",
      "valueDateTime": "2019-07-23"
