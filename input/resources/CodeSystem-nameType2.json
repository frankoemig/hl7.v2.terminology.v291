      "language": "de",
      "value": "ungültiger Name"
    } ],
    "property": [ {
      "code": "comment",
      "valueString": "A name that was wrongly used in the past and is now maintained only for the purposes of searching"
    }, {
      "code": "modified",
      "valueDateTime": "2015-07-13"
