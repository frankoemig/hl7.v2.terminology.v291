    "code": "AGG",
    "display": "Aggressive",
    "definition": "Aggressive",
    "property": [ {
      "code": "comment",
      "valueString": "A danger that can be associated with certain living subjects, including humans."
    }, {
      "code": "modified",
      "valueDateTime": "2015-07-13"
    }, {
