    "id": "1866",
    "code": "ER",
    "display": "Error/Reject conditions only",
    "definition": "Error/Reject conditions only.  Only MFA segments denoting errors must be returned via the application-level acknowledgment for this message",
    "designation": [ {
      "language": "de",
      "value": "Rückmeldung bei auftretenden Fehlern"
